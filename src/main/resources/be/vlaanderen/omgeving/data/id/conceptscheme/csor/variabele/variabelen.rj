   ,
  "https://data.omgeving.vlaanderen.be/id/collection/csor/variabele/fysische_eigenschappen" : { 
    "http://www.w3.org/2004/02/skos/core#prefLabel" : [ { 
      "type" : "literal" ,
      "value" : "Lijst van fysische eigenschappen." ,
      "lang" : "nl"
    }
     ] ,
    "http://www.w3.org/2004/02/skos/core#definition" : [ { 
      "type" : "literal" ,
      "value" : "Fysische eigenschappen zijn meetbare kenmerken van een stof of materiaal die veranderen zonder de chemische samenstelling aan te tasten, zoals fase, smeltpunt, dichtheid, kleur en thermische geleidbaarheid. Ze bepalen hoe een materiaal functioneert en reageert op de omgeving." ,
      "lang" : "nl"
    }
     ] ,
