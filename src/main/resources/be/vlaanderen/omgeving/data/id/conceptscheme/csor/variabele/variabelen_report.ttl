PREFIX xsd:              <http://www.w3.org/2001/XMLSchema#>

[ rdf:type     sh:ValidationReport;
  sh:conforms  false;
  sh:result    [ rdf:type                      sh:ValidationResult;
                 sh:focusNode                  <https://data.omgeving.vlaanderen.be/id/concept/csor/organisatiespecifiekereferentie/OSR_3221>;
                 sh:resultMessage              "Closed[https://data.omgeving.vlaanderen.be/ns/csor#heeftVariabele, https://data.omgeving.vlaanderen.be/ns/csor#ovoCode, http://www.w3.org/2004/02/skos/core#prefLabel, https://data.omgeving.vlaanderen.be/ns/csor#heeftParameter, https://data.omgeving.vlaanderen.be/ns/csor#referentieType, https://data.omgeving.vlaanderen.be/ns/csor#waarde, http://www.w3.org/2002/07/owl#deprecated, http://www.w3.org/1999/02/22-rdf-syntax-ns#type, https://data.omgeving.vlaanderen.be/ns/csor#referentieCategorie, http://www.w3.org/2004/02/skos/core#inScheme] Property = <http://www.w3.org/2004/02/skos/core#definition> : Object = \"Dit is een toelichting test\"@nl";
                 sh:resultPath                 skos:definition;
                 sh:resultSeverity             sh:Violation;
                 sh:sourceConstraintComponent  sh:ClosedConstraintComponent;
                 sh:sourceShape                csor-constraints:OrganisatieSpecifiekeReferentieShape;
                 sh:value                      "Dit is een toelichting test"@nl
               ];
  sh:result    [ rdf:type                      sh:ValidationResult;
                 sh:focusNode                  <https://data.omgeving.vlaanderen.be/id/concept/csor/organisatiespecifiekereferentie/OSR_3220>;
                 sh:resultMessage              "Closed[https://data.omgeving.vlaanderen.be/ns/csor#heeftVariabele, https://data.omgeving.vlaanderen.be/ns/csor#ovoCode, http://www.w3.org/2004/02/skos/core#prefLabel, https://data.omgeving.vlaanderen.be/ns/csor#heeftParameter, https://data.omgeving.vlaanderen.be/ns/csor#referentieType, https://data.omgeving.vlaanderen.be/ns/csor#waarde, http://www.w3.org/2002/07/owl#deprecated, http://www.w3.org/1999/02/22-rdf-syntax-ns#type, https://data.omgeving.vlaanderen.be/ns/csor#referentieCategorie, http://www.w3.org/2004/02/skos/core#inScheme] Property = <http://www.w3.org/2004/02/skos/core#definition> : Object = \"Tesing osr\"@nl";
                 sh:resultPath                 skos:definition;
                 sh:resultSeverity             sh:Violation;
                 sh:sourceConstraintComponent  sh:ClosedConstraintComponent;
                 sh:sourceShape                csor-constraints:OrganisatieSpecifiekeReferentieShape;
                 sh:value                      "Tesing osr"@nl
               ]
] .
